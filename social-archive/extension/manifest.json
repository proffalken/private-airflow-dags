{
  "manifest_version": 3,
  "name": "Social Archive Sync",
  "version": "1.0.0",
  "description": "Syncs Brave/Chrome bookmarks to your Social Archive instance.",
  "permissions": [
    "bookmarks",
    "alarms",
    "storage"
  ],
  "host_permissions": [
    "https://social-archive.wallace.network/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Social Archive Sync"
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
